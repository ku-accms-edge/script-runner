# =============================================================================
# Git認証用Secret (Private リポジトリ用)
# =============================================================================
#
# ⚠️注意: このファイルにトークンを直接記述してコミットしないでください！
#

apiVersion: v1
kind: Secret
metadata:
  name: git-credentials
type: Opaque
stringData:
  # GitHub Personal Access Token
  # https://github.com/settings/tokens で生成
  # Fine-grained token推奨: Contents の Read-only 権限のみ付与
  GIT_TOKEN: "YOUR_TOKEN_HERE"  # ← 実際のトークンに置き換え
